<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to the Apex services used by Agentforce Record Insights without expanding object or field visibility.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Agentforce Record Insights User</label>
    <classAccesses>
        <apexClass>RecordAdvisorController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>RecordCompareService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>RecordContextService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
